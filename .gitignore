# Keep Canoe Dock documentation-first. Do not commit private dumps or payloads.
*.img
*.bin
*.elf
*.mbn
*.zip
*.7z
*.rar
*.tar
*.tar.*
*.log
*.raw
*.dump
*.bak
*.backup
*.apk
*.apex
*.so
*.ko
*.pem
*.key

# Local working folders.
work/
tmp/
private/
backups/
payloads/
artifacts/

# Local OrangeFox forensic payloads. Keep summaries in docs/orangefox-port.
recovery-forensics/**
!recovery-forensics/
!recovery-forensics/README.md

# OrangeFox source snapshots should not absorb proprietary blobs or key material.
ports/orangefox-recovery/**/keys/
ports/orangefox-recovery/**/security/
