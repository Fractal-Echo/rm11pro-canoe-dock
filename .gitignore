# Keep Canoe Dock documentation-first. Do not commit private dumps or payloads.
out/
.repo/
*.img
*.bin
*.elf
!assets/abl_unlock.elf
*.mbn
*.zip
*.7z
*.rar
*.tar
*.tar.*
*.log
*.raw
*.dump
*.bak
*.backup
*.apk
*.apex
*.so
*.ko
*.pem
*.pk8
*.key
*.p12
*.jks
*.keystore
*.token
*.secret
.env
.env.*

# Explicit boot-chain and partition images. These are covered by *.img, kept
# here as a review tripwire for recovery/boot-chain work.
recovery.img
boot.img
init_boot.img
vendor_boot.img
dtbo.img
vbmeta*.img
super.img

# Local working folders.
work/
tmp/
private/
backups/
payloads/
payload-dumps/
payload_dumps/
edl/
edl-dumps/
edl_dumps/
raw-partition-backups/
raw_partition_backups/
partition-backups/
personal-logs/
logs/
artifacts/
canoe-dock-setup-files/

# Windows download sidecars copied through WSL/UNC paths.
*:Zone.Identifier

# Local OrangeFox forensic payloads. Keep summaries in docs/orangefox-port.
recovery-forensics/**
!recovery-forensics/
!recovery-forensics/README.md

# OrangeFox source snapshots should not absorb proprietary blobs or key material.
ports/orangefox-recovery/**/keys/
ports/orangefox-recovery/**/security/
ports/orangefox-recovery/**/prebuilt/kernel
ports/orangefox-recovery/**/prebuilt/dtbo.img
ports/orangefox-recovery/**/prebuilt/android16/dtbo.img
ports/orangefox-recovery/**/prebuilt/system/bin/
ports/orangefox-recovery/**/prebuilt/android16/system/bin/
ports/orangefox-recovery/**/prebuilt/android16/system/lib64/
ports/orangefox-recovery/**/prebuilt/android16/vendor/bin/
ports/orangefox-recovery/**/prebuilt/android16/vendor/lib64/
ports/orangefox-recovery/**/recovery/root/vendor/bin/
ports/orangefox-recovery/**/recovery/root/vendor/firmware/
ports/orangefox-recovery/**/recovery/root/system/bin/busybox
ports/orangefox-recovery/**/recovery/root/system/bin/dhcpcd
ports/orangefox-recovery/**/recovery/root/system/bin/wpa_cli
ports/orangefox-recovery/**/recovery/root/odm/etc/aac_richtap.config
